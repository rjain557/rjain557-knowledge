{
  "_comment": "Repo-local Claude Code settings for rjain557-knowledge / Cortex. Layered ON TOP of ~/.claude/settings.json — these hooks add to (not replace) the user-global ones.",
  "permissions": {
    "allow": [
      "Bash(git -C \"C:/Users/rjain/OneDrive - Technijian, Inc/Documents/obsidian/rjain557-knowledge/rjain557-knowledge\":*)",
      "Bash(pwsh -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/*.ps1\":*)",
      "Read(//c/Users/rjain/OneDrive - Technijian, Inc/Documents/obsidian/rjain557-knowledge/**)",
      "Read(//c/vscode/rjain557-knowledge/**)",
      "Edit(//c/Users/rjain/OneDrive - Technijian, Inc/Documents/obsidian/rjain557-knowledge/rjain557-knowledge/claude-memory/**)",
      "Write(//c/Users/rjain/OneDrive - Technijian, Inc/Documents/obsidian/rjain557-knowledge/rjain557-knowledge/claude-memory/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/retrieve.ps1\"",
            "timeout": 8,
            "statusMessage": "Retrieving from knowledge vault..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/impact-check.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/reindex.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/consolidate.ps1\"",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/preference-extract.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"c:/vscode/rjain557-knowledge/rjain557-knowledge/.claude/hooks/health-check.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
